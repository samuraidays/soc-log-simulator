{
  "_comment": "このファイルを config.local.json にコピーし、実トークン等を入れる。config.local.json は .gitignore 済みでコミットされない。config.json の値をここで上書きできる（hecの一部だけでOK）。",
  "hec": {
    "url": "https://<SplunkのIP>:8088",
    "token": "<発行した実HECトークン>",
    "index": "tpot_sim",
    "verify_tls": false
  },
  "feeds": {
    "_note": "tools/import_iocs.py が脅威フィード(abuse.ch)から実IOCを取得する際のAuth-Key。無料: https://auth.abuse.ch/",
    "abusech_auth_key": "<abuse.ch の Auth-Key>"
  }
}
